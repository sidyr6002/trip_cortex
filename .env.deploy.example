# .env.deploy.example — copy to .env.deploy and fill in values (gitignored)
# Retrieve Clerk ARNs with:
#   aws secretsmanager describe-secret --secret-id trip-cortex/<env>/clerk-secret-key --query ARN --output text
# Retrieve ACR agent ARNs with:
#   act workflow show --name trip-cortex-flight-search
#   act workflow show --name trip-cortex-flight-booking

DEV_CLERK_SECRET_ARN=arn:aws:secretsmanager:us-east-1:<account>:secret:trip-cortex/dev/clerk-secret-key-<suffix>
DEV_PORTAL_CREDENTIALS_ARN=arn:aws:secretsmanager:us-east-1:<account>:secret:trip-cortex/dev/portal-credentials-<suffix>
DEV_NOVA_ACT_SEARCH_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:<account>:runtime/trip_cortex_flight_search-<suffix>
DEV_NOVA_ACT_BOOKING_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:<account>:runtime/trip_cortex_flight_booking-<suffix>
DEV_DUMMY_PORTAL_URL=https://flysmart.dportal.workers.dev

STAGING_CLERK_SECRET_ARN=REPLACE_WITH_ACTUAL_SECRET_ARN
STAGING_PORTAL_CREDENTIALS_ARN=REPLACE_WITH_ACTUAL_SECRET_ARN
STAGING_NOVA_ACT_SEARCH_AGENT_ARN=REPLACE_WITH_ACTUAL_ARN
STAGING_NOVA_ACT_BOOKING_AGENT_ARN=REPLACE_WITH_ACTUAL_ARN
STAGING_DUMMY_PORTAL_URL=https://flysmart.dportal.workers.dev

PROD_CLERK_SECRET_ARN=REPLACE_WITH_ACTUAL_SECRET_ARN
PROD_PORTAL_CREDENTIALS_ARN=REPLACE_WITH_ACTUAL_SECRET_ARN
PROD_NOVA_ACT_SEARCH_AGENT_ARN=REPLACE_WITH_ACTUAL_ARN
PROD_NOVA_ACT_BOOKING_AGENT_ARN=REPLACE_WITH_ACTUAL_ARN
PROD_DUMMY_PORTAL_URL=https://flysmart.dportal.workers.dev
